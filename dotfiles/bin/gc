#!/bin/bash
set -eu

cd $(find-root .git)
GIT_DIR="$(git rev-parse --git-dir)"
touch "$GIT_DIR/git_message" || true
args=()
message=""
for arg in "$@"; do
  if [[ $message != "" ]]; then
    message="$message $arg"
    continue
  fi
  if [[ $arg == "-m" ]]; then
    message=" "
  else
    args+=("$arg")
  fi
done
if [[ "$message" != "" ]]; then
  args+=("-m")
  args+=("${message:2}")
fi
    
git commit -t "$GIT_DIR/git_message" "${args[@]}"
rv=$?
if [[ $rv == 0 ]]; then
  if [[ ! "$@" =~ "-m" ]]; then
    rm -f "$GIT_DIR/git_message"
  fi
fi
exit $rv
